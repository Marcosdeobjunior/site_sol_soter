<section class="page" id="page-tarefas">
    <!-- Header -->
    <div class="page-header" style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:28px">
      <div>
        <div class="page-title">Meu <span>Planejamento</span></div>
        <div class="page-subtitle">Calendário, foco e gestão de tarefas</div>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-ghost" onclick="tkOpenAnalytics()" style="display:flex;align-items:center;gap:6px">📊 Analytics</button>
        <button class="btn btn-primary" onclick="tkModalOpenForDate(tkCalState.selected)">✦ &nbsp;Nova Tarefa</button>
      </div>
    </div>

    <!-- KPIs -->
    <div class="grid-4" style="margin-bottom:28px">
      <div class="card"><div class="card-title">Total</div><div class="card-big-num" id="tk-total">0</div></div>
      <div class="card"><div class="card-title">Pendentes</div><div class="card-big-num" style="color:var(--accent5)" id="tk-pend">0</div></div>
      <div class="card"><div class="card-title">Concluídas</div><div class="card-big-num" style="color:var(--accent3)" id="tk-done">0</div></div>
      <div class="card"><div class="card-title">Progresso</div><div class="card-big-num" style="color:var(--accent2)" id="tk-pct">0%</div></div>
    </div>

    <!-- ── LINHA: LISTA COM ABAS (esquerda, 3fr) + FOCO DE HOJE (direita, 1fr) ── -->
    <div class="tk-top-row" style="margin-bottom:28px">

      <!-- Lista com abas (ocupa mais espaço) -->
      <div class="tk-list-section">
        <div class="tk-list-hd">
          <div class="tk-list-tabs" id="tk-list-tabs">
            <button class="tk-list-tab active" data-tab="pendentes"  onclick="tkListSetTab('pendentes')">⏳ Pendentes <span class="tk-tab-count" id="tktc-pendentes"></span></button>
            <button class="tk-list-tab"        data-tab="hoje"       onclick="tkListSetTab('hoje')">📅 Hoje <span class="tk-tab-count" id="tktc-hoje"></span></button>
            <button class="tk-list-tab"        data-tab="vencidas"   onclick="tkListSetTab('vencidas')">🔴 Vencidas <span class="tk-tab-count" id="tktc-vencidas"></span></button>
            <button class="tk-list-tab"        data-tab="sem-data"   onclick="tkListSetTab('sem-data')">🕳 Sem data <span class="tk-tab-count" id="tktc-sem-data"></span></button>
            <button class="tk-list-tab"        data-tab="concluidas" onclick="tkListSetTab('concluidas')">✅ Concluídas <span class="tk-tab-count" id="tktc-concluidas"></span></button>
            <button class="tk-list-tab"        data-tab="todas"      onclick="tkListSetTab('todas')">📋 Todas <span class="tk-tab-count" id="tktc-todas"></span></button>
          </div>
          <span class="tk-list-count" id="tk-list-count"></span>
        </div>
        <div class="tk-list-grid" id="tk-list-grid"></div>
      </div>

      <!-- Foco de hoje (coluna direita, menor) -->
      <div class="tk-focus-wrap" id="tk-focus-wrap">
        <div class="tk-focus-hd">
          <div class="tk-focus-hd-left">
            <div class="tk-focus-icon">⚡</div>
            <div>
              <div class="tk-focus-title">Foco de Hoje</div>
              <div class="tk-focus-sub" id="tk-focus-sub">—</div>
            </div>
          </div>
          <button class="tk-focus-add-btn" onclick="tkModalOpenForDate(tkToday())">+ Hoje</button>
        </div>
        <div class="tk-focus-list" id="tk-focus-list" style="display:flex;flex-direction:column;gap:8px">
          <div class="tk-focus-empty">Nenhuma tarefa para hoje 🎉</div>
        </div>
      </div>

    </div>

    <!-- ── CALENDÁRIO FULL WIDTH ── -->
    <div class="tk-cal-wrap">
      <div class="tk-cal-nav">
        <button class="tk-cal-arrow" onclick="tkCalPrev()">‹</button>
        <div>
          <div class="tk-cal-title" id="tk-cal-title">—</div>
        </div>
        <div style="display:flex;gap:8px;align-items:center">
          <button class="tk-cal-today-btn" onclick="tkCalGoToday()">Hoje</button>
          <button class="tk-cal-arrow" onclick="tkCalNext()">›</button>
          <button class="tk-focus-add-btn" onclick="tkModalOpenForDate(tkCalState.selected)" style="height:34px">+ Tarefa</button>
        </div>
      </div>
      <div class="tk-cal-dow-row">
        <div class="tk-cal-dow">Domingo</div><div class="tk-cal-dow">Segunda</div>
        <div class="tk-cal-dow">Terça</div><div class="tk-cal-dow">Quarta</div>
        <div class="tk-cal-dow">Quinta</div><div class="tk-cal-dow">Sexta</div>
        <div class="tk-cal-dow">Sábado</div>
      </div>
      <div class="tk-cal-days" id="tk-cal-days"></div>
    </div>
  </section>