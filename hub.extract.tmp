<div id="task-hub">
    <div class="hub-hero" id="taskh-hero">
      <img class="hub-hero-img" id="taskh-hero-img" src="" alt="">
      <div class="hub-hero-mesh"></div>
      <div class="hub-hero-overlay"></div>
      <div class="hub-hero-side"></div>
      <div class="hub-hero-lines"></div>
      <div class="hub-accent-bar" id="taskh-accent-bar"></div>
      <div class="hub-nav">
        <button class="hub-back-btn" onclick="taskHubClose()">← Planejamento</button>
        <div class="hub-nav-actions">
          <button class="hub-nav-btn done-btn" id="taskh-nav-done" onclick="taskHubToggleDone()">
            <span id="taskh-nav-done-icon">○</span><span id="taskh-nav-done-lbl">Concluir</span>
          </button>
          <button class="hub-nav-btn edit" onclick="taskHubDrawerOpen()">✎ Editar</button>
        </div>
      </div>
      <div class="hub-hero-content">
        <div class="hub-icon-bubble" id="taskh-icon">✅</div>
        <div class="hub-title-block">
          <div class="hub-cat-badge" id="taskh-badge">Tarefa</div>
          <div class="hub-title" id="taskh-title">Tarefa</div>
          <div class="hub-hero-meta" id="taskh-meta"></div>
        </div>
      </div>
    </div>

    <!-- Drawer backdrop + drawer -->
    <div id="taskh-drawer-bd" onclick="taskHubDrawerClose()"></div>
    <div id="taskh-drawer">
      <div class="hd-stripe"></div>
      <div class="hd-head">
        <div class="hd-head-icon" id="taskh-drawer-icon">✦</div>
        <div class="hd-head-info">
          <div class="hd-head-title" id="taskh-drawer-title">Editar tarefa</div>
          <div class="hd-head-sub">Alterações salvas ao clicar em salvar</div>
        </div>
        <button class="hd-close-btn" onclick="taskHubDrawerClose()">✕</button>
      </div>
      <div class="hd-body">
        <div class="hd-section">
          <div class="hd-section-lbl">Tarefa</div>
          <div class="hd-field">
            <div class="hd-field-lbl">Nome</div>
            <input class="hd-inp" id="tkd-nome" placeholder="Descrição da tarefa *">
          </div>
          <div class="hd-field">
            <div class="hd-field-lbl">Detalhes / observação</div>
            <textarea class="hd-inp" id="tkd-nota" placeholder="Contexto, links, lembretes…" style="min-height:76px"></textarea>
          </div>
        </div>
        <div class="hd-section">
          <div class="hd-section-lbl">Classificação</div>
          <div class="hd-row">
            <div class="hd-field">
              <div class="hd-field-lbl">Prioridade</div>
              <select class="hd-inp" id="tkd-prior">
                <option value="alta">🔴 Alta</option>
                <option value="media">🟡 Média</option>
                <option value="baixa">🟢 Baixa</option>
              </select>
            </div>
            <div class="hd-field">
              <div class="hd-field-lbl">Categoria</div>
              <select class="hd-inp" id="tkd-cat">
                <option>Pessoal</option><option>Trabalho</option>
                <option>Estudos</option><option>Saúde</option><option>Outros</option>
              </select>
            </div>
          </div>
          <div class="hd-field">
            <div class="hd-field-lbl">Cor de destaque</div>
            <div class="tk-modal-colors" id="tkd-colors"></div>
          </div>
        </div>
        <div class="hd-section">
          <div class="hd-section-lbl">Cronograma</div>
          <div class="hd-row">
            <div class="hd-field">
              <div class="hd-field-lbl">Data</div>
              <input class="hd-inp" id="tkd-data" type="date">
            </div>
            <div class="hd-field">
              <div class="hd-field-lbl">Hora</div>
              <input class="hd-inp" id="tkd-hora" type="time">
            </div>
          </div>
        </div>
      </div>
      <div class="hd-footer">
        <button class="hd-save-btn" onclick="taskHubDrawerSalvar()">✓ Salvar alterações</button>
        <div class="hd-footer-row">
          <button class="hd-cancel-btn" onclick="taskHubDrawerClose()">Cancelar</button>
          <button class="hd-del-btn" onclick="taskHubDelete()">🗑 Excluir tarefa</button>
        </div>
      </div>
    </div>

    <!-- Body -->
    <div class="hub-body">
      <!-- LEFT -->
      <div>
        <!-- Descrição / Nota -->
        <div class="hub-section" id="taskh-nota-section">
          <div class="hub-section-hd">
            <div class="hub-section-hd-icon">✦</div>
            <span class="hub-section-label">Detalhes</span>
          </div>
          <div id="taskh-nota-display"></div>
        </div>
        <!-- Subtarefas -->
        <div class="hub-section">
          <div class="hub-section-hd">
            <div class="hub-section-hd-icon">◈</div>
            <span class="hub-section-label">Subtarefas</span>
            <span id="taskh-sub-pct" style="margin-left:auto;font-size:10px;font-family:var(--font-mono);color:var(--muted)"></span>
          </div>
          <div class="taskh-sub-list" id="taskh-sub-list"></div>
          <div class="taskh-add-sub">
            <input class="taskh-add-sub-inp" id="taskh-new-sub" placeholder="Nova subtarefa…"
              onkeydown="if(event.key==='Enter')taskHubAddSub()">
            <button class="taskh-add-sub-btn" onclick="taskHubAddSub()">+ Add</button>
          </div>
        </div>
      </div>
      <!-- RIGHT sidebar -->
      <div>
        <!-- Progresso -->
        <div class="hub-section">
          <div class="hub-section-hd">
            <div class="hub-section-hd-icon">◎</div>
            <span class="hub-section-label">Progresso</span>
          </div>
          <div class="taskh-ring-wrap">
            <svg width="100" height="100" viewBox="0 0 100 100">
              <defs><linearGradient id="taskh-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="#7c6fcd"/><stop offset="100%" stop-color="#c8a96e"/>
              </linearGradient></defs>
              <circle cx="50" cy="50" r="40" fill="none" stroke="rgba(255,255,255,.05)" stroke-width="9"/>
              <circle cx="50" cy="50" r="40" fill="none" stroke="url(#taskh-grad)" stroke-width="9"
                stroke-dasharray="251.33" stroke-dashoffset="251.33" id="taskh-ring-fill"
                transform="rotate(-90 50 50)" style="transition:stroke-dashoffset 1.1s cubic-bezier(.22,1,.36,1)"/>
              <text x="50" y="47" text-anchor="middle" fill="var(--text)" font-family="var(--font-display)" font-size="17" font-weight="700" id="taskh-ring-pct">0%</text>
              <text x="50" y="62" text-anchor="middle" fill="var(--muted)" font-family="var(--font-mono)" font-size="8" id="taskh-ring-sub">subtarefas</text>
            </svg>
            <div class="taskh-ring-stats" id="taskh-ring-stats"></div>
          </div>
        </div>
        <!-- Cronograma -->
        <div class="hub-section" id="taskh-sched-section">
          <div class="hub-section-hd">
            <div class="hub-section-hd-icon">📅</div>
            <span class="hub-section-label">Cronograma</span>
          </div>
          <div id="taskh-sched-content"></div>
        </div>
        <!-- Prioridade + Categoria -->
        <div class="hub-section">
          <div class="hub-section-hd">
            <div class="hub-section-hd-icon">▸</div>
            <span class="hub-section-label">Classificação</span>
          </div>
          <div id="taskh-class-content"></div>
        </div>
        <!-- Concluir -->
        <div class="hub-section">
          <button class="taskh-done-btn pending" id="taskh-done-btn" onclick="taskHubToggleDone()">
            <span id="taskh-done-icon">○</span>
            <span id="taskh-done-lbl">Marcar como concluída</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Tips / dicas baseadas na tarefa -->
    <div class="hub-tips-wrap">
      <div class="hub-tips-hd">
        <div class="hub-tips-hd-icon">💡</div>
        <div>
          <div class="hub-tips-hd-title">Dicas para esta tarefa</div>
          <div class="hub-tips-hd-sub">Sugestões baseadas no status e prioridade</div>
        </div>
      </div>
      <div class="hub-tips-grid" id="taskh-tips-grid"></div>
    </div>
  </div>