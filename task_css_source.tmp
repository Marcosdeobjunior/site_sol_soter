  .tk-cal-wrap {
    background: rgba(12,11,24,.7); backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,.07); border-radius: 20px; padding: 26px;
  }
  .tk-cal-nav {
    display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px;
  }
  .tk-cal-title {
    font-family: var(--font-display); font-size: 19px; font-weight: 700; color: var(--text);
  }
  .tk-cal-arrow {
    width: 34px; height: 34px; border-radius: 10px;
    background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.09);
    color: var(--muted); font-size: 14px; cursor: pointer;
    display: flex; align-items: center; justify-content: center; transition: all .18s;
  }
  .tk-cal-arrow:hover { background: rgba(200,169,110,.14); color: var(--accent1); border-color: rgba(200,169,110,.3); }
  .tk-cal-today-btn {
    font-size: 10px; font-family: var(--font-mono); font-weight: 700; letter-spacing: 1px;
    padding: 5px 12px; border-radius: 8px; cursor: pointer;
    background: rgba(200,169,110,.08); border: 1px solid rgba(200,169,110,.2);
    color: rgba(200,169,110,.7); transition: all .18s;
  }
  .tk-cal-today-btn:hover { background: rgba(200,169,110,.18); color: var(--accent1); }

  .tk-cal-dow-row {
    display: grid; grid-template-columns: repeat(7,1fr); margin-bottom: 4px;
  }
  .tk-cal-dow {
    text-align: center; font-size: 9px; font-family: var(--font-mono); font-weight: 800;
    letter-spacing: 1.8px; text-transform: uppercase; color: rgba(122,117,144,.45);
    padding-bottom: 10px;
  }
  .tk-cal-days { display: grid; grid-template-columns: repeat(7,1fr); gap: 3px; }

  /* Células do calendário — altura expandida para mostrar task-cards */
  .tk-day {
    min-height: 110px; border-radius: 13px; cursor: pointer;
    display: flex; flex-direction: column; align-items: flex-start;
    justify-content: flex-start; padding: 10px 8px 8px;
    background: rgba(255,255,255,.018); border: 1px solid rgba(255,255,255,.05);
    transition: background .18s, border-color .18s, box-shadow .18s;
    position: relative; overflow: hidden; gap: 4px;
  }
  .tk-day:hover {
    background: rgba(255,255,255,.05); border-color: rgba(255,255,255,.1);
    box-shadow: 0 4px 16px rgba(0,0,0,.3);
  }
  .tk-day.other-month { opacity: .22; pointer-events: none; }
  .tk-day.today {
    background: rgba(200,169,110,.08); border-color: rgba(200,169,110,.35);
    box-shadow: inset 0 0 0 1px rgba(200,169,110,.12);
  }
  .tk-day.selected {
    background: rgba(124,111,205,.12); border-color: rgba(124,111,205,.4);
    box-shadow: 0 0 0 2px rgba(124,111,205,.2);
  }
  .tk-day.today.selected {
    background: rgba(200,169,110,.15); border-color: rgba(200,169,110,.55);
    box-shadow: 0 0 0 2px rgba(200,169,110,.18);
  }
  .tk-day-num {
    font-size: 12px; font-weight: 700; color: rgba(255,255,255,.6); line-height: 1;
    font-family: var(--font-display); align-self: flex-end;
    position: absolute; top: 8px; right: 9px;
  }
  .tk-day.today .tk-day-num {
    color: var(--accent1); background: rgba(200,169,110,.15);
    border-radius: 6px; padding: 1px 5px;
  }
  .tk-day.other-month .tk-day-num { color: var(--muted); }
  /* dots legacy — ocultos agora */
  .tk-day-dots { display: none; }
  .tk-day-dot  { display: none; }
  .tk-day-count { display: none; }

  /* ── Painel lateral do dia ── */
  .tk-day-panel {
    background: rgba(12,11,24,.7); backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,.07); border-radius: 20px; padding: 22px;
    position: sticky; top: 80px;
  }
  .tk-day-panel-hd {
    display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px;
  }
  .tk-day-panel-date {
    font-family: var(--font-display); font-size: 16px; font-weight: 700; color: var(--text);
  }
  .tk-day-panel-sub {
    font-size: 10px; font-family: var(--font-mono); color: var(--muted); margin-top: 2px; letter-spacing: .5px;
  }
  .tk-add-day-btn {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 14px; border-radius: 10px; cursor: pointer;
    background: rgba(200,169,110,.1); border: 1px solid rgba(200,169,110,.25);
    color: var(--accent1); font-family: var(--font-mono); font-size: 10px;
    font-weight: 800; letter-spacing: 1px; text-transform: uppercase; transition: all .18s;
  }
  .tk-add-day-btn:hover { background: rgba(200,169,110,.2); border-color: rgba(200,169,110,.5); transform: translateY(-1px); }

  .tk-day-task-list { display: flex; flex-direction: column; gap: 8px; }
  .tk-day-task {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; border-radius: 12px; cursor: pointer;
    background: rgba(255,255,255,.035); border: 1px solid rgba(255,255,255,.06);
    transition: all .18s;
  }
  .tk-day-task:hover { background: rgba(255,255,255,.065); border-color: rgba(255,255,255,.12); transform: translateX(2px); }
  .tk-day-task.done-task { opacity: .5; }
  .tk-day-task-check {
    width: 16px; height: 16px; border-radius: 5px; flex-shrink: 0;
    border: 1.5px solid; cursor: pointer;
    display: flex; align-items: center; justify-content: center; font-size: 9px;
    transition: all .18s;
  }
  .tk-day-task-check.checked { background: var(--check-color); border-color: var(--check-color); color: #fff; }
  .tk-day-task-info { flex: 1; min-width: 0; }
  .tk-day-task-nome {
    font-size: 12.5px; font-weight: 600; color: var(--text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .tk-day-task.done-task .tk-day-task-nome { text-decoration: line-through; color: var(--muted); }
  .tk-day-task-meta { font-size: 10px; font-family: var(--font-mono); color: var(--muted); margin-top: 2px; }
  .tk-day-empty {
    text-align: center; padding: 32px 16px; color: var(--muted);
    font-size: 12px; font-family: var(--font-mono);
  }
  .tk-day-empty-icon { font-size: 28px; margin-bottom: 8px; opacity: .4; }

  /* ── Modal de nova tarefa ── */
  .tk-modal-bd {
    position: fixed; inset: 0; z-index: 620;
    background: rgba(2,1,12,.8); backdrop-filter: blur(12px);
    display: none; align-items: center; justify-content: center; padding: 20px;
  }
  .tk-modal-bd.open { display: flex; animation: backdropIn .25s ease both; }
  .tk-modal {
    background: linear-gradient(160deg, #0e0c22 0%, #080718 100%);
    border: 1px solid rgba(255,255,255,.09);
    border-radius: 20px; width: 100%; max-width: 480px;
    box-shadow: 0 32px 80px rgba(0,0,0,.8), 0 0 0 1px rgba(200,169,110,.06);
    animation: modalIn .32s cubic-bezier(.16,1,.3,1) both;
    overflow: hidden;
  }
  .tk-modal-stripe {
    height: 2px; background: linear-gradient(90deg, #7c6fcd, #c8a96e 50%, transparent);
  }
  .tk-modal-head {
    padding: 20px 22px 16px; border-bottom: 1px solid rgba(255,255,255,.06);
    display: flex; align-items: center; justify-content: space-between;
  }
  .tk-modal-head-title {
    font-family: var(--font-display); font-size: 16px; font-weight: 700; color: var(--text);
  }
  .tk-modal-head-date {
    font-size: 10px; font-family: var(--font-mono); color: var(--muted); margin-top: 2px;
  }
  .tk-modal-close {
    width: 28px; height: 28px; border-radius: 50%; background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.09); color: var(--muted); font-size: 11px;
    cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .2s;
  }
  .tk-modal-close:hover { background: rgba(224,107,139,.18); color: var(--accent4); transform: rotate(90deg); }
  .tk-modal-body { padding: 20px 22px 22px; display: flex; flex-direction: column; gap: 14px; }
  .tk-modal-lbl {
    font-size: 9.5px; font-family: var(--font-mono); font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase; color: rgba(122,117,144,.6); margin-bottom: 6px;
  }
  .tk-modal-inp {
    width: 100%; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09);
    border-radius: 11px; padding: 11px 14px; color: var(--text); font-family: var(--font-ui);
    font-size: 13px; outline: none; box-sizing: border-box; transition: border-color .18s, box-shadow .18s;
    -webkit-appearance: none; appearance: none;
  }
  .tk-modal-inp:focus { border-color: rgba(200,169,110,.5); box-shadow: 0 0 0 3px rgba(200,169,110,.09); }
  .tk-modal-inp::placeholder { color: rgba(122,117,144,.35); }
  textarea.tk-modal-inp { min-height: 72px; resize: vertical; line-height: 1.65; }
  select.tk-modal-inp { color: var(--text); cursor: pointer; }
  select.tk-modal-inp option { background: #0e0c22; }
  .tk-modal-row { display: flex; gap: 10px; }
  .tk-modal-row > div { flex: 1; }
  .tk-modal-colors { display: flex; gap: 8px; flex-wrap: wrap; }
  .tk-color-opt {
    width: 26px; height: 26px; border-radius: 50%; cursor: pointer;
    border: 2.5px solid transparent; transition: transform .15s, border-color .15s;
  }
  .tk-color-opt:hover { transform: scale(1.15); }
  .tk-color-opt.sel { border-color: #fff; transform: scale(1.15); }
  .tk-modal-footer {
    padding: 14px 22px 18px; border-top: 1px solid rgba(255,255,255,.06);
    display: flex; gap: 8px;
  }
  .tk-modal-save {
    flex: 1; padding: 12px; border-radius: 12px; cursor: pointer;
    background: linear-gradient(135deg, rgba(200,169,110,.22), rgba(124,111,205,.18));
    border: 1px solid rgba(200,169,110,.4); color: #f0ead8;
    font-family: var(--font-mono); font-size: 11px; font-weight: 800; letter-spacing: 1.5px;
    text-transform: uppercase; transition: all .22s cubic-bezier(.22,1,.36,1);
  }
  .tk-modal-save:hover { background: linear-gradient(135deg, rgba(200,169,110,.36), rgba(124,111,205,.28)); transform: translateY(-1px); box-shadow: 0 6px 24px rgba(200,169,110,.2); }
  .tk-modal-cancel {
    padding: 12px 18px; border-radius: 12px; cursor: pointer;
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.08);
    color: var(--muted); font-family: var(--font-mono); font-size: 11px; font-weight: 700;
    letter-spacing: .8px; text-transform: uppercase; transition: all .18s;
  }
  .tk-modal-cancel:hover { background: rgba(255,255,255,.09); color: var(--text); }

  /* ══ TASK HUB FULLSCREEN ══════════════════════════════════════════════ */
  #task-hub {
    position: fixed; inset: 0; z-index: 500;
    background: #05040f; overflow-y: auto; overflow-x: hidden;
    scrollbar-width: thin; scrollbar-color: rgba(200,169,110,.12) transparent;
    display: none;
  }
  #task-hub.open { display: block; animation: hubFadeIn .45s cubic-bezier(.16,1,.3,1) both; }
  #task-hub.open .hub-hero-img { transform: scale(1); }
  #task-hub.open .hub-icon-bubble { animation: iconPop .6s .2s cubic-bezier(.34,1.56,.64,1) both; }

  /* Drawer de edição */
  #taskh-drawer-bd {
    position: fixed; inset: 0; z-index: 580;
    background: rgba(2,1,12,.72); backdrop-filter: blur(6px);
    opacity: 0; visibility: hidden; pointer-events: none;
    transition: opacity .32s, visibility .32s;
  }
  #taskh-drawer-bd.open { opacity: 1; visibility: visible; pointer-events: all; }
  #taskh-drawer {
    position: fixed; top: 0; right: 0; bottom: 0; z-index: 590;
    width: 420px; max-width: 96vw;
    background: linear-gradient(180deg, #0b0920 0%, #07061a 100%);
    border-left: 1px solid rgba(255,255,255,.08);
    box-shadow: -40px 0 120px rgba(0,0,0,.8);
    display: flex; flex-direction: column; overflow: clip;
    transform: translateX(110%); transition: transform .42s cubic-bezier(.16,1,.3,1);
  }
  #taskh-drawer.open { transform: translateX(0); }

  /* Subtarefas */
  .taskh-sub-list { display: flex; flex-direction: column; gap: 8px; }
  .taskh-sub-item {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px; border-radius: 12px;
    background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.06);
    transition: all .18s;
  }
  .taskh-sub-check {
    width: 18px; height: 18px; border-radius: 5px; flex-shrink: 0; cursor: pointer;
    border: 1.5px solid rgba(255,255,255,.2);
    display: flex; align-items: center; justify-content: center; font-size: 10px;
    transition: all .2s;
  }
  .taskh-sub-check.done { background: var(--accent3); border-color: var(--accent3); color: #fff; }
  .taskh-sub-text { flex: 1; font-size: 13px; color: var(--text); }
  .taskh-sub-text.done { text-decoration: line-through; color: var(--muted); }
  .taskh-sub-del {
    width: 22px; height: 22px; border-radius: 6px; flex-shrink: 0; cursor: pointer;
    background: transparent; border: none; color: rgba(224,107,139,.4); font-size: 11px;
    display: flex; align-items: center; justify-content: center; transition: all .18s;
  }
  .taskh-sub-del:hover { color: var(--accent4); background: rgba(224,107,139,.12); }
  .taskh-add-sub {
    display: flex; gap: 8px; margin-top: 10px;
  }
  .taskh-add-sub-inp {
    flex: 1; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.09);
    border-radius: 10px; padding: 9px 12px; color: var(--text); font-family: var(--font-ui);
    font-size: 12px; outline: none; transition: border-color .18s;
  }
  .taskh-add-sub-inp:focus { border-color: rgba(200,169,110,.45); }
  .taskh-add-sub-inp::placeholder { color: rgba(122,117,144,.35); }
  .taskh-add-sub-btn {
    padding: 9px 14px; border-radius: 10px; cursor: pointer;
    background: rgba(200,169,110,.1); border: 1px solid rgba(200,169,110,.25);
    color: var(--accent1); font-size: 11px; font-family: var(--font-mono);
    font-weight: 700; transition: all .18s;
  }
  .taskh-add-sub-btn:hover { background: rgba(200,169,110,.2); }

  /* Progress ring wrapper */
  .taskh-ring-wrap { display: flex; align-items: center; gap: 18px; }
  .taskh-ring-stats { flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .taskh-ring-stat { display: flex; justify-content: space-between; align-items: baseline; }
  .taskh-ring-stat-lbl { font-size: 10.5px; font-family: var(--font-mono); color: var(--muted); }
  .taskh-ring-stat-val { font-size: 15px; font-weight: 700; font-family: var(--font-display); }

  /* Done button */
  .taskh-done-btn {
    width: 100%; padding: 14px; border-radius: 13px; cursor: pointer;
    font-family: var(--font-mono); font-size: 11px; font-weight: 800;
    letter-spacing: 1.5px; text-transform: uppercase;
    display: flex; align-items: center; justify-content: center; gap: 9px;
    transition: all .24s cubic-bezier(.22,1,.36,1);
  }
  .taskh-done-btn.pending {
    background: rgba(94,196,168,.1); border: 1px solid rgba(94,196,168,.25); color: var(--accent3);
  }
  .taskh-done-btn.pending:hover { background: rgba(94,196,168,.2); border-color: rgba(94,196,168,.5); transform: translateY(-1px); }
  .taskh-done-btn.done-state {
    background: rgba(94,196,168,.18); border: 1px solid rgba(94,196,168,.45); color: var(--accent3);
  }
  .taskh-done-btn.done-state:hover { background: rgba(224,107,139,.1); border-color: rgba(224,107,139,.3); color: var(--accent4); }

  /* Nota display */
  .taskh-nota-text {
    font-size: 13px; line-height: 1.7; color: rgba(210,205,230,.8); font-family: var(--font-ui);
  }
  .taskh-nota-empty { font-size: 12px; color: rgba(122,117,144,.4); font-family: var(--font-mono); font-style: italic; }

  @media (max-width: 960px) {
    .tk-layout { grid-template-columns: 1fr; }
    .tk-day-panel { position: static; }
    #taskh-drawer { width: 100vw; max-width: 100vw; }
  }

  /* ══ LINHA FOCO + ABAS ══════════════════════════════════════════════ */
  .tk-top-row {
    display: grid;
    grid-template-columns: 3fr 1fr;
    gap: 16px;
    align-items: start;
    margin-bottom: 20px;
  }
  @media (max-width: 900px) { .tk-top-row { grid-template-columns: 1fr; } }

  /* ══ FOCO DE HOJE ═══════════════════════════════════════════════════ */
  .tk-focus-wrap {
    background: rgba(12,11,24,.75); backdrop-filter: blur(20px);
    border: 1px solid rgba(200,169,110,.15);
    border-radius: 20px; padding: 22px 26px;
    position: relative; overflow: hidden;
  }
  .tk-focus-wrap::before {
    content: ''; position: absolute; top:0; left:0; right:0; height:2px;
    background: linear-gradient(90deg, #c8a96e, #7c6fcd 50%, transparent);
  }
  .tk-focus-hd {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 18px; flex-wrap: wrap; gap: 10px;
  }
  .tk-focus-hd-left { display: flex; align-items: center; gap: 14px; }
  .tk-focus-icon {
    width: 42px; height: 42px; border-radius: 13px; flex-shrink: 0;
    background: rgba(200,169,110,.12); border: 1px solid rgba(200,169,110,.25);
    display: flex; align-items: center; justify-content: center; font-size: 20px;
    box-shadow: 0 4px 16px rgba(200,169,110,.1);
  }
  .tk-focus-title {
    font-family: var(--font-display); font-size: 18px; font-weight: 700; color: var(--text);
  }
  .tk-focus-sub {
    font-size: 11px; font-family: var(--font-mono); color: var(--muted);
    letter-spacing: .4px; margin-top: 2px;
  }
  .tk-focus-add-btn {
    padding: 9px 18px; border-radius: 11px; cursor: pointer;
    background: rgba(200,169,110,.1); border: 1px solid rgba(200,169,110,.25);
    color: var(--accent1); font-family: var(--font-mono); font-size: 10px;
    font-weight: 800; letter-spacing: 1px; text-transform: uppercase; transition: all .18s;
  }
  .tk-focus-add-btn:hover { background: rgba(200,169,110,.2); border-color: rgba(200,169,110,.5); transform: translateY(-1px); }
  .tk-focus-list {
    display: flex; flex-direction: column; gap: 8px;
  }
  .tk-focus-empty {
    grid-column: 1/-1; text-align: center; padding: 20px;
    font-size: 13px; font-family: var(--font-mono); color: var(--muted); font-style: italic;
  }
  /* Card de tarefa no foco */
  .tk-focus-card {
    padding: 14px 16px; border-radius: 14px; cursor: pointer;
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07);
    border-left: 3px solid var(--tk-color, #c8a96e);
    transition: all .2s; position: relative; overflow: hidden;
  }
  .tk-focus-card:hover { background: rgba(255,255,255,.08); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.3); }
  .tk-focus-card.done-card { opacity: .5; }
  .tk-focus-card-top { display: flex; align-items: center; gap: 9px; margin-bottom: 8px; }
  .tk-focus-card-check {
    width: 18px; height: 18px; border-radius: 5px; flex-shrink: 0; cursor: pointer;
    border: 1.5px solid var(--tk-color, #c8a96e);
    display: flex; align-items: center; justify-content: center; font-size: 10px;
    transition: all .18s; color: transparent;
  }
  .tk-focus-card-check.checked {
    background: var(--tk-color, #c8a96e); border-color: var(--tk-color, #c8a96e); color: #fff;
  }
  .tk-focus-card-nome {
    font-size: 13px; font-weight: 700; color: var(--text); flex: 1;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .tk-focus-card.done-card .tk-focus-card-nome { text-decoration: line-through; color: var(--muted); }
  .tk-focus-card-meta {
    display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
  }
  .tk-focus-card-pill {
    font-size: 9.5px; font-family: var(--font-mono); font-weight: 700; letter-spacing: .5px;
    padding: 2px 8px; border-radius: 10px;
    background: var(--tk-color, #c8a96e)18; color: var(--tk-color, #c8a96e);
    border: 1px solid var(--tk-color, #c8a96e)33;
  }
  .tk-focus-card-hora {
    font-size: 10px; font-family: var(--font-mono); color: var(--muted);
  }
  /* Progress bar no card de foco */
  .tk-focus-card-prog {
    margin-top: 8px; height: 3px; background: rgba(255,255,255,.06);
    border-radius: 3px; overflow: hidden;
  }
  .tk-focus-card-prog-fill {
    height: 100%; border-radius: 3px;
    background: var(--tk-color, #c8a96e); transition: width .6s;
  }

  /* ══ LISTA COM ABAS ═════════════════════════════════════════════════ */
  .tk-list-section {
    background: rgba(12,11,24,.7); backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,.07); border-radius: 20px;
    padding: 20px 24px;
  }
  .tk-list-hd {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 18px; flex-wrap: wrap; gap: 10px;
  }
  .tk-list-tabs { display: flex; gap: 4px; flex-wrap: wrap; }
  .tk-list-tab {
    padding: 7px 16px; border-radius: 10px; cursor: pointer; font-size: 11px;
    font-family: var(--font-mono); font-weight: 700; letter-spacing: .5px;
    background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07);
    color: var(--muted); transition: all .18s;
  }
  .tk-list-tab:hover { background: rgba(255,255,255,.08); color: var(--text); }
  .tk-list-tab.active {
    background: rgba(200,169,110,.14); border-color: rgba(200,169,110,.35);
    color: var(--accent1);
  }
  .tk-tab-count {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 17px; height: 17px; border-radius: 9px; padding: 0 4px;
    font-size: 9px; font-weight: 800; font-family: var(--font-mono);
    background: rgba(255,255,255,.08); color: var(--muted);
    margin-left: 4px; vertical-align: middle; transition: all .2s;
  }
  .tk-list-tab.active .tk-tab-count {
    background: rgba(200,169,110,.22); color: var(--accent1);
  }
  .tk-tab-count:empty { display: none; }
  .tk-list-count {
    font-size: 10px; font-family: var(--font-mono); color: var(--muted); letter-spacing: .5px;
  }
  /* Grid de cards de tarefa */
  .tk-list-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px;
  }
  .tk-list-empty {
    grid-column: 1/-1; text-align: center; padding: 40px 20px;
    font-size: 13px; font-family: var(--font-mono); color: var(--muted); font-style: italic;
  }
  .tk-list-empty-icon { font-size: 32px; margin-bottom: 10px; opacity: .4; }
  /* Card de tarefa na lista */
  .tk-task-card {
    padding: 16px 18px; border-radius: 16px; cursor: pointer;
    background: rgba(255,255,255,.035); border: 1px solid rgba(255,255,255,.07);
    border-left: 4px solid var(--tk-color, #c8a96e);
    transition: all .22s; position: relative;
  }
  .tk-task-card:hover { background: rgba(255,255,255,.07); transform: translateY(-2px); box-shadow: 0 10px 30px rgba(0,0,0,.3); }
  .tk-task-card.done-card { opacity: .55; }
  .tk-task-card-top { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 8px; }
  .tk-task-card-check {
    width: 20px; height: 20px; border-radius: 6px; flex-shrink: 0; cursor: pointer;
    border: 1.5px solid var(--tk-color, #c8a96e); margin-top: 1px;
    display: flex; align-items: center; justify-content: center; font-size: 11px;
    transition: all .18s; color: transparent;
  }
  .tk-task-card-check.checked {
    background: var(--tk-color, #c8a96e); border-color: var(--tk-color, #c8a96e); color: #fff;
  }
  .tk-task-card-nome {
    font-size: 14px; font-weight: 700; color: var(--text); flex: 1; line-height: 1.35;
  }
  .tk-task-card.done-card .tk-task-card-nome { text-decoration: line-through; color: var(--muted); }
  .tk-task-card-nota {
    font-size: 11.5px; color: var(--muted); line-height: 1.5; margin-bottom: 10px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .tk-task-card-footer {
    display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
  }
  .tk-task-card-pill {
    font-size: 9.5px; font-family: var(--font-mono); font-weight: 700; letter-spacing: .5px;
    padding: 3px 9px; border-radius: 10px;
  }
  .tk-task-card-date {
    font-size: 10.5px; font-family: var(--font-mono); color: var(--muted); margin-left: auto;
  }
  .tk-task-card-date.late { color: var(--accent4); }
  .tk-task-card-date.today-date { color: var(--accent3); }
  /* Sub progress no card */
  .tk-task-card-sub-prog {
    margin-top: 10px; display: flex; align-items: center; gap: 8px;
  }
  .tk-task-card-sub-track {
    flex: 1; height: 4px; background: rgba(255,255,255,.06); border-radius: 4px; overflow: hidden;
  }
  .tk-task-card-sub-fill {
    height: 100%; border-radius: 4px; background: var(--tk-color, #c8a96e); transition: width .6s;
  }
  .tk-task-card-sub-lbl {
    font-size: 9.5px; font-family: var(--font-mono); color: var(--muted); flex-shrink: 0;
  }

  /* ══ CALENDÁRIO FULL WIDTH ══════════════════════════════════════════ */
  /* override: remover grid com sidebar */
  .tk-cal-wrap {
    border-radius: 20px;
  }
  /* dias maiores para mostrar cards */
  .tk-cal-days { display: grid; grid-template-columns: repeat(7,1fr); gap: 4px; }
  .tk-day {
    min-height: 110px;
    aspect-ratio: unset;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 8px 8px 6px;
  }
  .tk-day-num { margin-bottom: 4px; }
  .tk-day-dots { display: none; } /* substituído por mini-cards */
  .tk-day-count { position: static; margin-top: auto; }

  /* mini-cards dentro de cada célula do calendário */
  /* Task cards dentro das células do calendário */
  .tk-cal-task-card {
    width: 100%; border-radius: 7px; padding: 4px 7px;
    font-size: 10.5px; font-family: var(--font-ui); font-weight: 600;
    color: rgba(255,255,255,.9); line-height: 1.3;
    background: var(--tk-color, #c8a96e)22;
    border-left: 2.5px solid var(--tk-color, #c8a96e);
    cursor: pointer; transition: all .15s;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    flex-shrink: 0;
  }
  .tk-cal-task-card:hover { background: var(--tk-color, #c8a96e)44; transform: translateX(1px); }
  .tk-cal-task-card.done-mini { opacity: .38; text-decoration: line-through; }
  .tk-cal-more {
    font-size: 9px; font-family: var(--font-mono); font-weight: 700;
    color: rgba(255,255,255,.35); letter-spacing: .5px;
    padding: 2px 5px; background: rgba(255,255,255,.05); border-radius: 5px;
    align-self: flex-start; flex-shrink: 0;
  }

  /* ══ ANALYTICS DE TAREFAS ═══════════════════════════════════════════ */
  #tk-analytics {
    position: fixed; inset: 0; z-index: 500;
    background: #05040f;
    overflow-y: auto; overflow-x: hidden;
    scrollbar-width: thin; scrollbar-color: rgba(200,169,110,.12) transparent;
    display: none;
  }
  #tk-analytics.open { display: block; animation: hubFadeIn .45s cubic-bezier(.16,1,.3,1) both; }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .tk-focus-list { grid-template-columns: 1fr 1fr; }
    .tk-list-grid { grid-template-columns: 1fr; }
    .tk-day { min-height: 80px; }
